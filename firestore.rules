rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isValidTask(data) {
      return data.keys().hasOnly(['title', 'status', 'priority', 'order', 'createdAt', 'updatedAt', 'completed', 'pinned', 'subtasks', 'isChecklist', 'userId', 'description', 'dueDate'])
        && data.title is string
        && (data.description == null || data.description is string)
        && data.status is string
        && data.priority is string
        && data.order is number
        && data.pinned is bool
        && data.subtasks is list
        && data.isChecklist is bool
        && data.completed is bool
        && data.userId is string
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && (data.dueDate == null || data.dueDate is timestamp);
    }

    function isSafeCreate(data) {
      return data.completed == false && data.createdAt == request.time;
    }

    function isSafeUpdate(data) {
      return data.createdAt == resource.data.createdAt;
    }

    // Public Demo Data - READ ONLY
    // Skip users can see this, but no one can modify it via the app
    match /public/demoTasks {
      allow read: if true;
      allow write: if false;
    }

    // Auth Tasks
    match /users/{uid}/tasks/{taskId} {
      allow read, delete: if request.auth != null && request.auth.uid == uid;
      allow create, update: if request.auth != null && request.auth.uid == uid 
                    && isValidTask(request.resource.data) 
                    && (request.method == 'create' ? isSafeCreate(request.resource.data) : isSafeUpdate(request.resource.data));
    }
  }
}
