rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isValidTask(data) {
      return data.keys().hasAll(['title', 'status', 'priority', 'order', 'createdAt', 'updatedAt', 'completed', 'pinned', 'subtasks', 'isChecklist', 'userId'])
        && data.title is string
        && (data.description == null || data.description is string)
        && data.status is string
        && data.priority is string
        && data.order is number
        && data.pinned is bool
        && data.subtasks is list
        && data.isChecklist is bool
        && data.completed is bool
        && data.userId is string
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && (data.dueDate == null || data.dueDate is timestamp);
    }

    function isSafeCreate(data) {
      // Prevent completing instantly on creation and prevent fake timestamps
      return data.completed == false
        && data.createdAt == request.time;
    }

    function isSafeUpdate(data) {
      // Prevent backdating / altering createdAt
      return data.createdAt == resource.data.createdAt;
    }

    // New Public Demo Structure (Option A-ish)
    // ROOT -> public (collection) -> demo (document) -> demoTasks (collection)
    match /public/demo/demoTasks/{taskId} {
      allow read: if true;
      allow write: if isValidTask(request.resource.data) 
                    && (request.method == 'create' ? isSafeCreate(request.resource.data) : isSafeUpdate(request.resource.data));
    }

    // Original User Tasks
    match /users/{uid}/tasks/{taskId} {
      allow read, delete: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid 
                    && isValidTask(request.resource.data) && isSafeCreate(request.resource.data);
      allow update: if request.auth != null && request.auth.uid == uid 
                    && isValidTask(request.resource.data) && isSafeUpdate(request.resource.data);
    }
  }
}
