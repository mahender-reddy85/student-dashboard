rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isValidTask(data) {
      return data.keys().hasAny(['title', 'status', 'priority']) 
        && data.get('title', '') is string
        && data.get('status', 'todo') is string
        && (data.get('description', null) == null || data.get('description', '') is string)
        && data.get('order', 0) is number
        && data.get('pinned', false) is bool
        && data.get('subtasks', []) is list
        && data.get('isChecklist', false) is bool
        && data.get('completed', false) is bool
        && data.get('createdAt', request.time) is timestamp
        && data.get('updatedAt', request.time) is timestamp
        && (data.get('dueDate', null) == null || data.get('dueDate', request.time) is timestamp);
    }

    function isSafeCreate(data) {
      return data.get('completed', false) == false 
          && data.get('createdAt', request.time) == request.time;
    }

    function isSafeUpdate(data) {
      return data.get('createdAt', resource.data.createdAt) == resource.data.createdAt;
    }

    // Shared Demo Data in Tiered Structure
    // Public (Col) -> demo (Doc) -> demoTasks (Sub-Col)
    match /public/demo/demoTasks/{taskId} {
      allow read: if true;
      allow write: if false;
    }

    // Auth Tasks (Private)
    match /users/{uid}/tasks/{taskId} {
      allow read, delete: if request.auth != null && request.auth.uid == uid;
      
      allow create: if request.auth != null && request.auth.uid == uid 
                  && isValidTask(request.resource.data) 
                  && isSafeCreate(request.resource.data);
      
      allow update: if request.auth != null && request.auth.uid == uid 
                  && isValidTask(request.resource.data) 
                  && isSafeUpdate(request.resource.data);
    }
  }
}
